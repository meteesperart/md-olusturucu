<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Botones de la barra de herramientas -->
    <sys:String x:Key="toolbar_new">＋ Nuevo</sys:String>
    <sys:String x:Key="toolbar_open">📂 Abrir</sys:String>
    <sys:String x:Key="toolbar_save">💾 Guardar</sys:String>
    <sys:String x:Key="toolbar_delete">🗑 Eliminar</sys:String>
    <sys:String x:Key="toolbar_theme">🌙 Tema</sys:String>
    <sys:String x:Key="toolbar_settings">⚙ Ajustes</sys:String>
    <sys:String x:Key="toolbar_export_html">🌐 Exportar HTML</sys:String>
    <sys:String x:Key="toolbar_preview_on">⊡ Vista previa</sys:String>
    <sys:String x:Key="toolbar_preview_off">⊞ Vista previa</sys:String>
    <sys:String x:Key="toolbar_about">Acerca de</sys:String>

    <!-- Información sobre herramientas -->
    <sys:String x:Key="tooltip_new">Nuevo archivo (Ctrl+N)</sys:String>
    <sys:String x:Key="tooltip_open">Abrir archivo (Ctrl+O)</sys:String>
    <sys:String x:Key="tooltip_save">Guardar (Ctrl+S)</sys:String>
    <sys:String x:Key="tooltip_preview_toggle">Mostrar / ocultar vista previa</sys:String>
    <sys:String x:Key="tooltip_hide_preview">Ocultar vista previa</sys:String>

    <!-- Etiquetas -->
    <sys:String x:Key="lbl_files_header">ARCHIVOS</sys:String>
    <sys:String x:Key="lbl_no_file">Seleccione un archivo del panel izquierdo para editar</sys:String>
    <sys:String x:Key="lbl_preview_header">VISTA PREVIA</sys:String>
    <sys:String x:Key="lbl_shortcuts">Ctrl+S Guardar  ·  Ctrl+N Nuevo  ·  Ctrl+O Abrir</sys:String>

    <!-- Ventana de ajustes -->
    <sys:String x:Key="settings_title">Ajustes</sys:String>
    <sys:String x:Key="settings_md_folder">Carpeta MD:</sys:String>
    <sys:String x:Key="settings_font">Fuente:</sys:String>
    <sys:String x:Key="settings_font_color">Color de fuente:</sys:String>
    <sys:String x:Key="settings_language">Idioma:</sys:String>
    <sys:String x:Key="settings_browse">Explorar</sys:String>
    <sys:String x:Key="settings_cancel">Cancelar</sys:String>
    <sys:String x:Key="settings_save">Guardar</sys:String>
    <sys:String x:Key="settings_folder_dialog">Seleccionar carpeta MD</sys:String>
    <sys:String x:Key="restart_required">Reinicie la aplicación para aplicar el cambio de idioma.</sys:String>

    <!-- Ventana Acerca de -->
    <sys:String x:Key="about_title">Acerca de</sys:String>
    <sys:String x:Key="about_version_label">Versión</sys:String>
    <sys:String x:Key="about_developer_label">Desarrollador</sys:String>
    <sys:String x:Key="about_company_label">Empresa</sys:String>
    <sys:String x:Key="about_ok">Aceptar</sys:String>

    <!-- Barra de estado -->
    <sys:String x:Key="status_default">MD Creador</sys:String>
    <sys:String x:Key="status_unsaved">cambios sin guardar</sys:String>
    <sys:String x:Key="status_saved">guardado</sys:String>
    <sys:String x:Key="status_new_file">Nuevo Archivo</sys:String>

    <!-- Diálogos de archivo -->
    <sys:String x:Key="dialog_filter_md">Archivos Markdown (*.md)|*.md|Todos los archivos (*.*)|*.*</sys:String>
    <sys:String x:Key="dialog_title_open">Abrir archivo Markdown</sys:String>
    <sys:String x:Key="menu_desktop_shortcut">Crear acceso directo en el escritorio</sys:String>

    <!-- Exportación HTML -->
    <sys:String x:Key="export_no_file">Por favor, seleccione un archivo primero.</sys:String>
    <sys:String x:Key="export_success">Archivo HTML creado:</sys:String>
    <sys:String x:Key="export_error">Error al crear HTML:</sys:String>

    <!-- Opciones de color -->
    <sys:String x:Key="color_default">Por defecto (Tema)</sys:String>
    <sys:String x:Key="color_white">Blanco</sys:String>
    <sys:String x:Key="color_light_gray">Gris claro</sys:String>
    <sys:String x:Key="color_yellow">Amarillo</sys:String>
    <sys:String x:Key="color_orange">Naranja</sys:String>
    <sys:String x:Key="color_red">Rojo</sys:String>
    <sys:String x:Key="color_pink">Rosa</sys:String>
    <sys:String x:Key="color_green">Verde</sys:String>
    <sys:String x:Key="color_blue">Azul</sys:String>
    <sys:String x:Key="color_light_blue">Azul claro</sys:String>
    <sys:String x:Key="color_purple">Morado</sys:String>
    <sys:String x:Key="color_black">Negro</sys:String>
    <sys:String x:Key="color_dark_gray">Gris oscuro</sys:String>

</ResourceDictionary>
