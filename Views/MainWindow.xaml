<Window x:Class="MDOlusturucu.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        mc:Ignorable="d"
        Title="MD Oluşturucu"
        Icon="/Resources/app.ico"
        Height="700" Width="1200"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackground}">

    <!-- Klavye kısayolları -->
    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveFileCommand}"/>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NewFileCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenFileDialogCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <Style x:Key="FileListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="12,8"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Margin="4,2">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ListItemHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ListItemSelected}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="{DynamicResource ButtonBackground}"/>
            <Setter Property="Foreground"       Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="12,6"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ButtonHoverBackground}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{DynamicResource TitleBarBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                <Button Content="{DynamicResource toolbar_new}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding NewFileCommand}"
                        ToolTip="{DynamicResource tooltip_new}"
                        Margin="0,0,6,0"/>
                <Button Content="{DynamicResource toolbar_open}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding OpenFileDialogCommand}"
                        ToolTip="{DynamicResource tooltip_open}"
                        Margin="0,0,6,0"/>
                <Button Content="{DynamicResource toolbar_save}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding SaveFileCommand}"
                        IsEnabled="{Binding HasSelectedFile}"
                        ToolTip="{DynamicResource tooltip_save}"
                        Margin="0,0,6,0"/>
                <Button Content="{DynamicResource toolbar_delete}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding DeleteFileCommand}"
                        IsEnabled="{Binding HasSelectedFile}"
                        Margin="0,0,6,0"/>

                <Separator Width="1" Height="24"
                           Background="{DynamicResource BorderColor}"
                           Margin="6,0"/>

                <Button Content="{DynamicResource toolbar_theme}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding ToggleThemeCommand}"
                        Margin="6,0,6,0"/>
                <Button Content="{DynamicResource toolbar_settings}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding OpenSettingsCommand}"
                        Margin="0,0,6,0"/>

                <Separator Width="1" Height="24"
                           Background="{DynamicResource BorderColor}"
                           Margin="0,0,6,0"/>

                <Button Content="{DynamicResource toolbar_export_html}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        IsEnabled="{Binding HasSelectedFile}"
                        Click="ExportHtmlButton_Click"
                        Margin="0,0,6,0"/>

                <Button x:Name="PreviewToggleButton"
                        Content="{DynamicResource toolbar_preview_on}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Click="PreviewToggleButton_Click"
                        ToolTip="{DynamicResource tooltip_preview_toggle}"
                        Margin="0,0,6,0"/>

                <Button Content="{DynamicResource toolbar_about}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Click="AboutButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Ana içerik -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="150" MaxWidth="400"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sol panel -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SidebarBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{DynamicResource lbl_files_header}"
                               Foreground="{DynamicResource MutedText}"
                               FontSize="11" FontWeight="SemiBold"
                               Margin="16,12,16,8"/>
                    <ListBox x:Name="FileListBox"
                             ItemsSource="{Binding Files}"
                             SelectedItem="{Binding SelectedFile}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="8,0,8,8"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemContainerStyle="{StaticResource FileListItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBlock x:Name="FileNameBlock"
                                               Text="{Binding Name}"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis"
                                               MouseDown="FileNameBlock_MouseDown"/>
                                    <TextBox x:Name="FileNameBox"
                                             Text="{Binding Name, Mode=OneTime}"
                                             Foreground="{DynamicResource PrimaryText}"
                                             Background="{DynamicResource EditorBackground}"
                                             BorderBrush="{DynamicResource AccentColor}"
                                             BorderThickness="1"
                                             FontSize="13"
                                             Padding="2,1"
                                             Visibility="Collapsed"
                                             KeyDown="FileNameBox_KeyDown"
                                             LostFocus="FileNameBox_LostFocus"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- GridSplitter sol/sağ -->
            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource SplitterBackground}"
                          Cursor="SizeWE"/>

            <!-- Sağ panel -->
            <Grid Grid.Column="2">

                <!-- Boş durum -->
                <TextBlock Text="{DynamicResource lbl_no_file}"
                           Foreground="{DynamicResource MutedText}"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelectedFile}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Editör + Önizleme -->
                <Grid x:Name="EditorPreviewGrid">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelectedFile}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="200"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*" MinWidth="200"/>
                    </Grid.ColumnDefinitions>

                    <!-- AvalonEdit editör -->
                    <avalon:TextEditor
                        x:Name="EditorBox"
                        Grid.Column="0"
                        ShowLineNumbers="False"
                        WordWrap="True"
                        FontSize="14"
                        BorderThickness="0"
                        Padding="12"/>

                    <!-- GridSplitter editör/önizleme -->
                    <GridSplitter x:Name="EditorPreviewSplitter"
                                  Grid.Column="1"
                                  Width="5"
                                  HorizontalAlignment="Stretch"
                                  Background="{DynamicResource SplitterBackground}"
                                  Cursor="SizeWE"/>

                    <!-- Önizleme -->
                    <Border x:Name="PreviewPanel"
                            Grid.Column="2"
                            Background="{DynamicResource PreviewBackground}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1,0,0,0">
                        <DockPanel>
                            <Border DockPanel.Dock="Top"
                                    Background="{DynamicResource TitleBarBackground}"
                                    BorderBrush="{DynamicResource BorderColor}"
                                    BorderThickness="0,0,0,1"
                                    Padding="12,6">
                                <Grid>
                                    <TextBlock Text="{DynamicResource lbl_preview_header}"
                                               Foreground="{DynamicResource MutedText}"
                                               FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <Button Content="✕"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Width="22" Height="22"
                                            Padding="0"
                                            FontSize="11"
                                            Cursor="Hand"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{DynamicResource MutedText}"
                                            ToolTip="{DynamicResource tooltip_hide_preview}"
                                            Click="PreviewToggleButton_Click"/>
                                </Grid>
                            </Border>
                            <WebBrowser x:Name="PreviewBrowser"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- Durum çubuğu -->
        <Border Grid.Row="2"
                Background="{DynamicResource TitleBarBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,1,0,0">
            <DockPanel Margin="12,0">
                <TextBlock DockPanel.Dock="Right"
                           Text="{DynamicResource lbl_shortcuts}"
                           Foreground="{DynamicResource MutedText}"
                           FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource SecondaryText}"
                           FontSize="11" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
