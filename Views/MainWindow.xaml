<Window x:Class="MDOlusturucu.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:local="clr-namespace:MDOlusturucu.Views"
        mc:Ignorable="d"
        Title="MD Oluşturucu"
        Icon="/Resources/app.ico"
        Height="700" Width="1200"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackground}">

    <!-- Klavye kısayolları -->
    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveFileCommand}"/>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NewFileCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenFileDialogCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <Style x:Key="FileListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="12,8"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Margin="4,2">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ListItemHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ListItemSelected}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="{DynamicResource ButtonBackground}"/>
            <Setter Property="Foreground"       Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="12,6"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ButtonHoverBackground}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HtmlToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource ButtonBackground}"/>
            <Setter Property="Foreground"      Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="8,3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="MinWidth"        Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ButtonHoverBackground}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:BoolToHiddenConverter x:Key="BoolToHidden"/>

        <!-- Editör bağlam menüsü stilleri -->
        <Style x:Key="EditorContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background"      Value="{DynamicResource SidebarBackground}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" ShadowDepth="4" Opacity="0.28" Direction="270"/>
                            </Border.Effect>
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="12,5"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Margin="2,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ListItemHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorMenuSeparatorStyle" TargetType="Separator">
            <Setter Property="Background" Value="{DynamicResource BorderColor}"/>
            <Setter Property="Height"     Value="1"/>
            <Setter Property="Margin"     Value="8,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1"
                                Background="{TemplateBinding Background}"
                                Margin="{TemplateBinding Margin}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{DynamicResource TitleBarBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                <Button Content="{DynamicResource toolbar_new}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding NewFileCommand}"
                        ToolTip="{DynamicResource tooltip_new}"
                        Margin="0,0,6,0"/>
                <Button Content="{DynamicResource toolbar_new_html}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding NewHtmlFileCommand}"
                        ToolTip="Yeni HTML dosyası"
                        Margin="0,0,6,0"/>
                <Button Content="{DynamicResource toolbar_open}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding OpenFileDialogCommand}"
                        ToolTip="{DynamicResource tooltip_open}"
                        Margin="0,0,6,0"/>
                <Button Content="{DynamicResource toolbar_save}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding SaveFileCommand}"
                        IsEnabled="{Binding HasSelectedFile}"
                        ToolTip="{DynamicResource tooltip_save}"
                        Margin="0,0,6,0"/>
                <Button Content="{DynamicResource toolbar_delete}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding DeleteFileCommand}"
                        IsEnabled="{Binding HasSelectedFile}"
                        Margin="0,0,6,0"/>

                <Separator Width="1" Height="24"
                           Background="{DynamicResource BorderColor}"
                           Margin="6,0"/>

                <Button Content="{DynamicResource toolbar_theme}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding ToggleThemeCommand}"
                        Margin="6,0,6,0"/>
                <Button Content="{DynamicResource toolbar_settings}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding OpenSettingsCommand}"
                        Margin="0,0,6,0"/>

                <Separator Width="1" Height="24"
                           Background="{DynamicResource BorderColor}"
                           Margin="0,0,6,0"/>

                <Button Content="{DynamicResource toolbar_export_html}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        IsEnabled="{Binding CanExportHtml}"
                        Click="ExportHtmlButton_Click"
                        Margin="0,0,6,0"/>

                <Button x:Name="PreviewToggleButton"
                        Content="{DynamicResource toolbar_preview_on}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Click="PreviewToggleButton_Click"
                        ToolTip="{DynamicResource tooltip_preview_toggle}"
                        Margin="0,0,6,0"/>

                <Button Content="{DynamicResource toolbar_about}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Click="AboutButton_Click"/>
            </StackPanel>
        </Border>

        <!-- HTML biçimlendirme araç çubuğu (yalnızca HTML dosyası seçiliyken görünür) -->
        <Border Grid.Row="1"
                Background="{DynamicResource TitleBarBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,0,0,1"
                Visibility="{Binding IsHtmlFileSelected, Converter={StaticResource BoolToHidden}}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,4">
                <Button Content="B" Style="{StaticResource HtmlToolbarButtonStyle}"
                        FontWeight="Bold" ToolTip="Kalın &lt;b&gt;"
                        Click="HtmlBold_Click" Margin="0,0,3,0"/>
                <Button Content="I" Style="{StaticResource HtmlToolbarButtonStyle}"
                        FontStyle="Italic" ToolTip="İtalik &lt;i&gt;"
                        Click="HtmlItalic_Click" Margin="0,0,3,0"/>
                <Button Style="{StaticResource HtmlToolbarButtonStyle}"
                        ToolTip="Altı çizili &lt;u&gt;"
                        Click="HtmlUnderline_Click" Margin="0,0,3,0">
                    <TextBlock TextDecorations="Underline">U</TextBlock>
                </Button>
                <Button Style="{StaticResource HtmlToolbarButtonStyle}"
                        ToolTip="Üzeri çizili &lt;s&gt;"
                        Click="HtmlStrike_Click" Margin="0,0,3,0">
                    <TextBlock TextDecorations="Strikethrough">S</TextBlock>
                </Button>

                <Separator Width="1" Height="20" Background="{DynamicResource BorderColor}" Margin="4,0"/>

                <Button Content="H1" Style="{StaticResource HtmlToolbarButtonStyle}"
                        FontWeight="Bold" ToolTip="Başlık 1 &lt;h1&gt;"
                        Click="HtmlH1_Click" Margin="3,0,3,0"/>
                <Button Content="H2" Style="{StaticResource HtmlToolbarButtonStyle}"
                        FontWeight="Bold" ToolTip="Başlık 2 &lt;h2&gt;"
                        Click="HtmlH2_Click" Margin="0,0,3,0"/>
                <Button Content="H3" Style="{StaticResource HtmlToolbarButtonStyle}"
                        FontWeight="Bold" ToolTip="Başlık 3 &lt;h3&gt;"
                        Click="HtmlH3_Click" Margin="0,0,3,0"/>
                <Button Content="P" Style="{StaticResource HtmlToolbarButtonStyle}"
                        ToolTip="Paragraf &lt;p&gt;"
                        Click="HtmlP_Click" Margin="0,0,3,0"/>

                <Separator Width="1" Height="20" Background="{DynamicResource BorderColor}" Margin="4,0"/>

                <Button Content="code" Style="{StaticResource HtmlToolbarButtonStyle}"
                        FontFamily="Cascadia Code, Consolas" ToolTip="Satır içi kod &lt;code&gt;"
                        Click="HtmlCode_Click" Margin="3,0,3,0"/>
                <Button Content="pre" Style="{StaticResource HtmlToolbarButtonStyle}"
                        FontFamily="Cascadia Code, Consolas" ToolTip="Kod bloğu &lt;pre&gt;"
                        Click="HtmlPre_Click" Margin="0,0,3,0"/>

                <Separator Width="1" Height="20" Background="{DynamicResource BorderColor}" Margin="4,0"/>

                <Button Content="a" Style="{StaticResource HtmlToolbarButtonStyle}"
                        ToolTip="Bağlantı &lt;a href=&quot;&quot;&gt;"
                        Click="HtmlLink_Click" Margin="3,0,3,0"/>
                <Button Content="img" Style="{StaticResource HtmlToolbarButtonStyle}"
                        ToolTip="Görsel &lt;img src=&quot;&quot;&gt;"
                        Click="HtmlImg_Click" Margin="0,0,3,0"/>
                <Button Content="hr" Style="{StaticResource HtmlToolbarButtonStyle}"
                        ToolTip="Yatay çizgi &lt;hr&gt;"
                        Click="HtmlHr_Click" Margin="0,0,3,0"/>
                <Button Content="ul" Style="{StaticResource HtmlToolbarButtonStyle}"
                        ToolTip="Sırasız liste &lt;ul&gt;&lt;li&gt;"
                        Click="HtmlUl_Click" Margin="0,0,3,0"/>
                <Button Content="ol" Style="{StaticResource HtmlToolbarButtonStyle}"
                        ToolTip="Numaralı liste &lt;ol&gt;&lt;li&gt;"
                        Click="HtmlOl_Click" Margin="0,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Ana içerik -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="150" MaxWidth="400"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sol panel -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SidebarBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{DynamicResource lbl_files_header}"
                               Foreground="{DynamicResource MutedText}"
                               FontSize="11" FontWeight="SemiBold"
                               Margin="16,12,16,8"/>
                    <ListBox x:Name="FileListBox"
                             ItemsSource="{Binding Files}"
                             SelectedItem="{Binding SelectedFile}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="8,0,8,8"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemContainerStyle="{StaticResource FileListItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBlock x:Name="FileNameBlock"
                                               Text="{Binding Name}"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis"
                                               MouseDown="FileNameBlock_MouseDown"/>
                                    <TextBox x:Name="FileNameBox"
                                             Text="{Binding Name, Mode=OneTime}"
                                             Foreground="{DynamicResource PrimaryText}"
                                             Background="{DynamicResource EditorBackground}"
                                             BorderBrush="{DynamicResource AccentColor}"
                                             BorderThickness="1"
                                             FontSize="13"
                                             Padding="2,1"
                                             Visibility="Collapsed"
                                             KeyDown="FileNameBox_KeyDown"
                                             LostFocus="FileNameBox_LostFocus"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- GridSplitter sol/sağ -->
            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource SplitterBackground}"
                          Cursor="SizeWE"/>

            <!-- Sağ panel -->
            <Grid Grid.Column="2">

                <!-- Boş durum -->
                <TextBlock Text="{DynamicResource lbl_no_file}"
                           Foreground="{DynamicResource MutedText}"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelectedFile}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Editör + Önizleme -->
                <Grid x:Name="EditorPreviewGrid">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelectedFile}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="200"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*" MinWidth="200"/>
                    </Grid.ColumnDefinitions>

                    <!-- AvalonEdit editör -->
                    <avalon:TextEditor
                        x:Name="EditorBox"
                        Grid.Column="0"
                        ShowLineNumbers="False"
                        WordWrap="True"
                        FontSize="14"
                        BorderThickness="0"
                        Padding="12">
                        <avalon:TextEditor.ContextMenu>
                            <ContextMenu Style="{StaticResource EditorContextMenuStyle}"
                                         Opened="EditorContextMenu_Opened">
                                <MenuItem x:Name="CtxCut"
                                          Header="{DynamicResource menu_cut}"
                                          Style="{StaticResource EditorMenuItemStyle}"
                                          Click="EditorContextCut_Click"/>
                                <MenuItem x:Name="CtxCopy"
                                          Header="{DynamicResource menu_copy}"
                                          Style="{StaticResource EditorMenuItemStyle}"
                                          Click="EditorContextCopy_Click"/>
                                <MenuItem x:Name="CtxPaste"
                                          Header="{DynamicResource menu_paste}"
                                          Style="{StaticResource EditorMenuItemStyle}"
                                          Click="EditorContextPaste_Click"/>
                                <Separator Style="{StaticResource EditorMenuSeparatorStyle}"/>
                                <MenuItem Header="{DynamicResource menu_select_all}"
                                          Style="{StaticResource EditorMenuItemStyle}"
                                          Click="EditorContextSelectAll_Click"/>
                                <Separator Style="{StaticResource EditorMenuSeparatorStyle}"/>
                                <MenuItem x:Name="CtxUndo"
                                          Header="{DynamicResource menu_undo}"
                                          Style="{StaticResource EditorMenuItemStyle}"
                                          Click="EditorContextUndo_Click"/>
                                <MenuItem x:Name="CtxRedo"
                                          Header="{DynamicResource menu_redo}"
                                          Style="{StaticResource EditorMenuItemStyle}"
                                          Click="EditorContextRedo_Click"/>
                            </ContextMenu>
                        </avalon:TextEditor.ContextMenu>
                    </avalon:TextEditor>

                    <!-- GridSplitter editör/önizleme -->
                    <GridSplitter x:Name="EditorPreviewSplitter"
                                  Grid.Column="1"
                                  Width="5"
                                  HorizontalAlignment="Stretch"
                                  Background="{DynamicResource SplitterBackground}"
                                  Cursor="SizeWE"/>

                    <!-- Önizleme -->
                    <Border x:Name="PreviewPanel"
                            Grid.Column="2"
                            Background="{DynamicResource PreviewBackground}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1,0,0,0">
                        <DockPanel>
                            <Border DockPanel.Dock="Top"
                                    Background="{DynamicResource TitleBarBackground}"
                                    BorderBrush="{DynamicResource BorderColor}"
                                    BorderThickness="0,0,0,1"
                                    Padding="12,6">
                                <Grid>
                                    <TextBlock Text="{DynamicResource lbl_preview_header}"
                                               Foreground="{DynamicResource MutedText}"
                                               FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <Button Content="✕"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Width="22" Height="22"
                                            Padding="0"
                                            FontSize="11"
                                            Cursor="Hand"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{DynamicResource MutedText}"
                                            ToolTip="{DynamicResource tooltip_hide_preview}"
                                            Click="PreviewToggleButton_Click"/>
                                </Grid>
                            </Border>
                            <WebBrowser x:Name="PreviewBrowser"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- Durum çubuğu -->
        <Border Grid.Row="3"
                Background="{DynamicResource TitleBarBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,1,0,0">
            <DockPanel Margin="12,0">
                <TextBlock DockPanel.Dock="Right"
                           Text="{DynamicResource lbl_shortcuts}"
                           Foreground="{DynamicResource MutedText}"
                           FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource SecondaryText}"
                           FontSize="11" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
