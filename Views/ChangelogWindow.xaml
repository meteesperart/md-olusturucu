<Window x:Class="MDOlusturucu.Views.ChangelogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sürüm Geçmişi"
        Width="520" Height="500"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackground}"
        ShowInTaskbar="False">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <WebBrowser x:Name="ChangelogBrowser" Grid.Row="0"/>

        <Border Grid.Row="1"
                Background="{DynamicResource SidebarBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Button x:Name="CloseBtn"
                    Content="Kapat"
                    HorizontalAlignment="Center"
                    Click="CloseBtn_Click"
                    Padding="28,8"
                    FontSize="13"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{DynamicResource AccentColor}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Button.Foreground>
                    <SolidColorBrush Color="#1E1E2E"/>
                </Button.Foreground>
            </Button>
        </Border>
    </Grid>
</Window>
