<Window x:Class="MDOlusturucu.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource about_title}"
        Width="340" Height="240"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackground}"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedText}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Width"      Value="90"/>
        </Style>
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="OkButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource AccentColor}"/>
            <Setter Property="Foreground"      Value="#1E1E2E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="28,8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Uygulama adı -->
        <TextBlock Grid.Row="0"
                   Text="MD Oluşturucu"
                   Foreground="{DynamicResource AccentColor}"
                   FontSize="20"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>

        <!-- Versiyon -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBlock Text="{DynamicResource about_version_label}"
                       Style="{StaticResource LabelStyle}"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="VersionText" Style="{StaticResource ValueStyle}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Yapımcı -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBlock Text="{DynamicResource about_developer_label}"
                       Style="{StaticResource LabelStyle}"
                       VerticalAlignment="Center"/>
            <TextBlock Text="Mete Esperart" Style="{StaticResource ValueStyle}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Firma -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBlock Text="{DynamicResource about_company_label}"
                       Style="{StaticResource LabelStyle}"
                       VerticalAlignment="Center"/>
            <TextBlock Text="OKASER" Style="{StaticResource ValueStyle}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Tamam butonu -->
        <Button Grid.Row="8"
                Content="{DynamicResource about_ok}"
                Style="{StaticResource OkButtonStyle}"
                HorizontalAlignment="Center"
                Click="OkButton_Click"
                IsDefault="True"/>
    </Grid>
</Window>
